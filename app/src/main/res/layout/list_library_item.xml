<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:background="@drawable/background_selectable"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <ImageView
        android:id="@+id/iv_library_item_icon"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_weight="0"
        android:padding="12dp"
        app:srcCompat="@drawable/ic_folder" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_library_item_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/library_item_title_placeholder"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tv_library_item_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/library_item_subtitle_placeholder"
            android:textSize="12sp" />
    </LinearLayout>

    <ImageView
        android:id="@+id/iv_library_item_delete"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_weight="0"
        android:padding="12dp"
        android:background="@drawable/background_selectable"
        android:clickable="true"
        android:focusable="true"
        app:srcCompat="@drawable/ic_close" />
</LinearLayout>