<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/ll_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".MainActivity"
    tools:ignore="NestedWeights">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_main_cover_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:layout_weight="1"
        android:padding="16dp">

        <ImageView
            android:id="@+id/iv_main_cover"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:contentDescription="@string/acc_cover"
            android:visibility="visible"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.497"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/cover_placeholder" />

        <TextView
            android:id="@+id/tv_main_scrub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/background_scrub"
            android:paddingStart="20dp"
            android:paddingTop="4dp"
            android:paddingEnd="20dp"
            android:paddingBottom="4dp"
            android:text="@string/main_placeholder_scrub_display"
            android:textColor="@color/scrub_foreground"
            android:textSize="40sp"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Space
                android:layout_width="14dp"
                android:layout_height="match_parent"
                android:layout_weight="0" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="vertical">

                <kr.pe.sinu.uranus.AlwaysFocusedTextView
                    android:id="@+id/tv_main_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="0"
                    android:ellipsize="marquee"
                    android:marqueeRepeatLimit="marquee_forever"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:text="@string/main_placeholder_title"
                    android:textStyle="bold" />

                <kr.pe.sinu.uranus.AlwaysFocusedTextView
                    android:id="@+id/tv_main_subtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="0"
                    android:ellipsize="marquee"
                    android:marqueeRepeatLimit="marquee_forever"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:text="@string/main_placeholder_subtitle" />

            </LinearLayout>

            <ImageView
                android:id="@+id/iv_main_playlist"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_weight="0"
                android:background="@drawable/background_selectable"
                android:clickable="true"
                android:contentDescription="@string/acc_playlist"
                android:focusable="true"
                android:padding="12dp"
                app:srcCompat="@drawable/ic_list" />

            <Space
                android:layout_width="8dp"
                android:layout_height="match_parent"
                android:layout_weight="0" />

            <ImageView
                android:id="@+id/iv_main_more"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_weight="0"
                android:background="@drawable/background_selectable"
                android:clickable="true"
                android:contentDescription="@string/acc_more"
                android:focusable="true"
                android:padding="12dp"
                app:srcCompat="@drawable/ic_more" />
        </LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_weight="1" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="0"
            android:orientation="horizontal">

            <Space
                android:layout_width="14dp"
                android:layout_height="match_parent"
                android:layout_weight="0" />

            <TextView
                android:id="@+id/tv_main_time_current"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="start"
                android:text="@string/main_placeholder_time" />

            <TextView
                android:id="@+id/tv_main_time_total"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:text="@string/main_placeholder_time" />

            <Space
                android:layout_width="14dp"
                android:layout_height="match_parent"
                android:layout_weight="0" />
        </LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_weight="1" />

        <SeekBar
            android:id="@+id/sb_main_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="24dp"
            android:paddingEnd="24dp" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_weight="0" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="0"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/iv_main_previous"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_weight="0"
                android:background="@drawable/background_selectable"
                android:clickable="true"
                android:contentDescription="@string/acc_prev"
                android:focusable="true"
                android:padding="12dp"
                app:srcCompat="@drawable/ic_previous" />

            <Space
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_weight="1" />

            <ImageView
                android:id="@+id/iv_main_repeat"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_weight="0"
                android:background="@drawable/background_selectable"
                android:clickable="true"
                android:contentDescription="@string/acc_repeat_none"
                android:focusable="true"
                android:padding="12dp"
                app:srcCompat="@drawable/ic_line_end" />

            <ImageView
                android:id="@+id/iv_main_play_pause"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_weight="0"
                android:background="@drawable/background_selectable"
                android:clickable="true"
                android:contentDescription="@string/acc_play"
                android:focusable="true"
                android:padding="8dp"
                app:srcCompat="@drawable/ic_play" />

            <ImageView
                android:id="@+id/iv_main_settings"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_weight="0"
                android:background="@drawable/background_selectable"
                android:clickable="true"
                android:contentDescription="@string/acc_settings"
                android:focusable="true"
                android:padding="12dp"
                app:srcCompat="@drawable/ic_settings" />

            <Space
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_weight="1" />

            <ImageView
                android:id="@+id/iv_main_next"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_weight="0"
                android:background="@drawable/background_selectable"
                android:clickable="true"
                android:contentDescription="@string/acc_next"
                android:focusable="true"
                android:padding="12dp"
                app:srcCompat="@drawable/ic_next" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>